    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2",
