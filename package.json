    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "daisyui": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0"
