{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "column_width": {
      "type": "number",
      "minimum": 0.1,
      "maximum": 2
    },
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "width": {
            "type": "number",
            "minimum": 0.1,
            "maximum": 2
          },
          "cells": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": {
                  "type": "string"
                },
                "text_color": {
                  "type": "string",
                  "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
                },
                "bg_color": {
                  "type": "string",
                  "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$"
                }
              },
              "required": ["text", "text_color", "bg_color"],
              "additionalProperties": false
            }
          }
        },
        "required": ["cells"],
        "additionalProperties": false
      }
    }
  },
  "required": ["column_width", "columns"],
  "additionalProperties": false,
  "$id": "https://a1678991.github.io/tag-table-editor/tag-table.schema.json",
  "title": "TagTable",
  "description": "Tag table definition for VRChat YodoTagBuilder. Max 64 cells total across all columns."
}
