{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "plugins": ["import", "typescript", "unicorn"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "ignorePatterns": [".svelte-kit/**", "build/**", "*.config.ts", "*.config.js"],
  "rules": {
    "no-unused-vars": "error",
    "eqeqeq": "error",
    "import/no-cycle": "error",
    "import/no-duplicates": "error"
  }
}
